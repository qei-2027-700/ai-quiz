# ──────────────────────────────────────────────
# Backend
# ──────────────────────────────────────────────

# サーバーポート
PORT=8081

# PostgreSQL 接続文字列
DATABASE_URL=postgres://postgres:postgres@localhost:5433/lifecycle_dev?sslmode=disable

# JWT 署名シークレット（本番では RS256 の秘密鍵パスに変更）
JWT_SECRET=change-me-in-production

# Claude API キー（AI フィードバック生成）
ANTHROPIC_API_KEY=sk-ant-...

# CORS 許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:5173

# Google OAuth（ログイン）
# Google Cloud Console の OAuth クライアントを作成して設定してください。
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# 例: http://localhost:8081/auth/google/callback
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback
# /auth/google/start?return_to=... の return_to 許可オリジン（カンマ区切り）
AUTH_RETURN_TO_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin（CSV import の Basic 認証）
ADMIN_USER=admin
ADMIN_PASS=change-me

# ──────────────────────────────────────────────
# Frontend（Vite: VITE_ プレフィックス必須）
# ──────────────────────────────────────────────

# バックエンド API エンドポイント
VITE_API_URL=http://localhost:8081

# ブランド名（UI/UX で表示されるアプリ名称）
VITE_APP_BRAND_NAME=ai-quiz

# モックモード（Vercel デプロイ時など BE なしで動かす場合は true）
VITE_USE_MOCK=false
