# API 設定
VITE_API_URL=http://localhost:8081
VITE_USE_MOCK=true

# ブランド・テーマ設定
VITE_APP_BRAND_NAME=ai-quiz
VITE_APP_TAGLINE=生成AIの理解度を試そう
VITE_APP_DESCRIPTION=RAG・Agent・LLMの知識を10問で確認。4段階ランクで実力を測ろう。
VITE_APP_MASCOT_VARIANT=default

# ジャンルラベル（未設定の場合はデフォルト値を使用）
VITE_APP_GENRE_AI_BASICS=AI基礎
VITE_APP_GENRE_AI_SERVICES=AIサービス
VITE_APP_GENRE_ENGINEERING=AIコーディング
