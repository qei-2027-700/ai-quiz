{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@ai-quiz/shared": ["./packages/shared/src/index.ts"],
      "@ai-quiz/shared/*": ["./packages/shared/src/*"],
      "@ai-quiz/api-client": ["./packages/api-client/src/index.ts"],
      "@ai-quiz/api-client/*": ["./packages/api-client/src/*"]
    }
  },
  "include": ["src", "scripts", "packages/shared/src", "packages/api-client/src"]
}
